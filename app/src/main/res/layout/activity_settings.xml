<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_ground_color"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/theme_color"
        app:navigationIcon="@drawable/ic_title_left"
        app:title="设置"
        app:titleTextColor="@color/white" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/dp_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_solid_layout_white_16"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/targetAppLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="目标应用"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iconView"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="#F1F1F1"
                        app:shapeAppearance="@style/RoundedStyle" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:id="@+id/msgChannelLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="消息渠道"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/channelView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textSize="@dimen/sp_16"
                        android:textStyle="bold" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:id="@+id/taskConfigLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center_vertical"
                        android:text="任务配置"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_arrow_right" />
                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/dp_16"
                android:background="@drawable/bg_solid_layout_white_16"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="通知监听"
                            android:textColor="@color/text_default_color"
                            android:textSize="@dimen/sp_16" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tipsView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_4"
                            android:text="通知监听服务未开启，无法监听打卡通知"
                            android:textColor="@color/red"
                            android:textSize="@dimen/sp_10" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/noticeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="手势辅助"
                            android:textColor="@color/text_default_color"
                            android:textSize="@dimen/sp_16" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="@dimen/dp_4"
                            android:singleLine="true"
                            android:text="开启后，支持单手指上下滑动屏幕开启/关闭伪灭屏"
                            android:textSize="@dimen/sp_10" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/gestureDetectorSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="退回桌面"
                            android:textColor="@color/text_default_color"
                            android:textSize="@dimen/sp_16" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="@dimen/dp_4"
                            android:singleLine="true"
                            android:text="开启后，打卡倒计时结束，会先退回桌面再启动本软件"
                            android:textSize="@dimen/sp_10" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/backToHomeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_solid_layout_white_16"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/openTestLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="唤起测试"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_arrow_right" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:id="@+id/notificationLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@color/white"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="通知记录"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_arrow_right" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:id="@+id/introduceLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@color/white"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="常见问题"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/ic_arrow_right" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:background="#CCC" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:background="@drawable/bg_solid_layout_white_16"
                    android:paddingHorizontal="@dimen/dp_16">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center_vertical"
                        android:text="当前版本"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/appVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>