<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_ground_color"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/theme_color"
        app:navigationIcon="@drawable/ic_title_left"
        app:title="消息渠道"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 企业微信 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_16"
            android:background="@drawable/bg_solid_layout_white_16"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dp_16"
                android:text="企业微信"
                android:textColor="@color/text_default_color"
                android:textSize="@dimen/sp_16" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#CCC" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/itemLayoutHeight"
                android:background="@drawable/bg_solid_layout_white_16"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="80dp"
                    android:layout_height="36dp"
                    android:gravity="center_vertical"
                    android:text="key"
                    android:textColor="@color/text_default_color"
                    android:textSize="@dimen/sp_16" />

                <com.pengxh.kt.lite.widget.DeleteEditText
                    android:id="@+id/wxKeyView"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="end|center_vertical"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textSize="@dimen/sp_16" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/wxRadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_8"
                    android:layout_weight="1"
                    android:text="选它" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendWxButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="2dp"
                    android:text="测试企业微信推送" />
            </LinearLayout>
        </LinearLayout>

        <!-- QQ邮件 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:background="@drawable/bg_solid_layout_white_16"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dp_16"
                android:text="QQ邮箱"
                android:textColor="@color/text_default_color"
                android:textSize="@dimen/sp_16" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#CCC" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_solid_layout_white_16"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="80dp"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="发件箱"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.pengxh.kt.lite.widget.DeleteEditText
                        android:id="@+id/emailSendAddressView"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="2"
                        android:background="@null"
                        android:gravity="end|center_vertical"
                        android:hint="如：123456789"
                        android:inputType="number"
                        android:maxLength="15"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sp_16" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="\@qq.com"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="80dp"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="授权码"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.pengxh.kt.lite.widget.DeleteEditText
                        android:id="@+id/emailSendCodeView"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:gravity="end|center_vertical"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sp_16" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/emailLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="80dp"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="收件箱"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.pengxh.kt.lite.widget.DeleteEditText
                        android:id="@+id/emailInboxView"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="2"
                        android:background="@null"
                        android:gravity="end|center_vertical"
                        android:hint="如：xxxxx@qq.com"
                        android:inputType="textEmailAddress"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sp_16" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/emailTitleLayout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/itemLayoutHeight"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="80dp"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="邮件标题"
                        android:textColor="@color/text_default_color"
                        android:textSize="@dimen/sp_16" />

                    <com.pengxh.kt.lite.widget.DeleteEditText
                        android:id="@+id/emailTitleView"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="2"
                        android:background="@null"
                        android:gravity="end|center_vertical"
                        android:hint="如：打卡结果通知"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textSize="@dimen/sp_16" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/qqRadioButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_8"
                        android:layout_weight="1"
                        android:text="选它" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sendEmailButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="2dp"
                        android:text="测试QQ邮件发送" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>